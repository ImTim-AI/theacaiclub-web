---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Catering | The Açai Club" description="Catering by The Açai Club. Açai bowls, smoothies, and fruit platters for offices, events, and parties across Reading, Beaconsfield, and Datchet.">

  <!-- Hero -->
  <section class="pt-28 pb-16 bg-dark">
    <div class="max-w-[1400px] mx-auto px-8 text-center">
      <h1 class="font-heading text-5xl sm:text-6xl font-black uppercase tracking-tight text-light leading-tight">
        Catering
      </h1>
      <p class="mt-4 text-grey text-lg max-w-xl mx-auto">
        Fresh açai bowls, smoothies & fruit platters for offices, events & parties.
      </p>
    </div>
  </section>

  <!-- What we offer -->
  <section class="bg-dark-surface py-20">
    <div class="max-w-[1400px] mx-auto px-8">
      <h2 class="font-heading text-2xl font-bold uppercase tracking-tight text-light mb-10 text-center">
        What we offer
      </h2>
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border text-center">
          <h3 class="font-heading font-normal text-light text-xl mb-2">Açai bowls</h3>
          <p class="text-grey text-sm leading-relaxed">Made fresh to order with your choice of toppings.</p>
        </div>
        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border text-center">
          <h3 class="font-heading font-normal text-light text-xl mb-2">Smoothies & drinks</h3>
          <p class="text-grey text-sm leading-relaxed">Bottled smoothies, juices & matcha for events of any size.</p>
        </div>
        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border text-center">
          <h3 class="font-heading font-normal text-light text-xl mb-2">Fruit platters</h3>
          <p class="text-grey text-sm leading-relaxed">Grazing-style platters of fresh seasonal fruit.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Get in touch -->
  <section class="py-24 bg-dark">
    <div class="max-w-3xl mx-auto px-8 text-center">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold uppercase tracking-tight text-light mb-4">
        Get in touch
      </h2>
      <p class="text-grey text-base mb-10 leading-relaxed">
        Tell us your numbers, date & location. We'll come back with a tailored quote.
      </p>
      <a href="mailto:hello@theacaiclub.com?subject=Catering%20enquiry" class="inline-flex px-10 py-4 bg-taupe text-white font-heading font-bold uppercase tracking-wider text-sm rounded-full hover:bg-taupe-dark transition-colors">
        Email us
      </a>
      <p class="mt-6 text-grey text-sm">
        Or call your nearest store: Reading <a href="tel:01182288750" class="text-charcoal hover:text-light transition-colors">0118 228 8750</a>, Beaconsfield <a href="tel:01494370876" class="text-charcoal hover:text-light transition-colors">01494 370876</a>, Datchet <a href="tel:01753297015" class="text-charcoal hover:text-light transition-colors">01753 297015</a>.
      </p>
    </div>
  </section>

</Layout>
