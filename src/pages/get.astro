---
// Instant app-store router. Scanned from a QR code.
// iPhone/iPad -> App Store, Android -> Google Play.
// If detection fails or it's a desktop/unknown visitor, fall back to the full
// /app marketing page (which shows both store buttons) so nobody hits a dead end.
const IOS_URL = 'https://apps.apple.com/gb/app/the-a%C3%A7ai-club/id6478923734';
const ANDROID_URL = 'https://play.google.com/store/apps/details?id=com.epostechnologies.theacaiclub';
const FALLBACK = '/app';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Get the app | The Açai Club</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="/favicon.ico" />
  <!-- No-JS fallback: send to the marketing page after a beat -->
  <noscript><meta http-equiv="refresh" content={`0; url=${FALLBACK}`} /></noscript>
  <!-- Redirect before paint so nothing flashes -->
  <script is:inline define:vars={{ IOS_URL, ANDROID_URL, FALLBACK }}>
    (function () {
      var ua = navigator.userAgent || navigator.vendor || '';
      var isAndroid = /android/i.test(ua);
      var isIOS = /iPhone|iPad|iPod/i.test(ua) ||
        (/Macintosh/.test(ua) && typeof document !== 'undefined' && 'ontouchend' in document);
      if (isAndroid) { window.location.replace(ANDROID_URL); }
      else if (isIOS) { window.location.replace(IOS_URL); }
      else { window.location.replace(FALLBACK); }   // desktop / unknown -> marketing page
    })();
  </script>
  <style>
    html,body{margin:0;height:100%;background:#1a1a1a;color:#9a948e;
      font-family:Inter,system-ui,-apple-system,sans-serif;
      display:flex;align-items:center;justify-content:center}
    a{color:#f5f1ec}
  </style>
</head>
<body>
  <!-- Only seen for the split second before redirect, or if JS is off -->
  <p>Taking you to the app… <a href={FALLBACK}>tap here</a> if nothing happens.</p>
</body>
</html>
