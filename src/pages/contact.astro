---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | The Açai Club" description="Get in touch with The Açai Club. Find store phone numbers, email addresses & opening hours.">

  <!-- Hero -->
  <section class="pt-28 pb-16 bg-dark">
    <div class="max-w-[1400px] mx-auto px-8 text-center">
      <h1 class="font-heading text-5xl sm:text-6xl font-black uppercase tracking-tight text-light leading-tight">
        Get in Touch
      </h1>
      <p class="mt-4 text-grey text-lg max-w-lg mx-auto">
        Questions about your order, a store visit, or something else? We're here.
      </p>
    </div>
  </section>

  <!-- Store contacts -->
  <section class="bg-dark-surface py-20">
    <div class="max-w-[1400px] mx-auto px-8">
      <h2 class="font-heading text-2xl font-bold uppercase tracking-tight text-light mb-10 text-center">
        Our Stores
      </h2>
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">

        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border">
          <h3 class="font-heading font-black uppercase tracking-tight text-light text-xl mb-1">Reading</h3>
          <p class="text-grey text-sm mb-4">85 Kings Road, RG1 3DD</p>
          <div class="space-y-2 text-sm">
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-charcoal shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href="tel:01182288750" class="text-grey hover:text-light transition-colors">0118 228 8750</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-charcoal shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 4l6 6M22 4l-6 6M4 20l4-4m12 4l-4-4M12 12v8"/></svg>
              <a href="mailto:reading@theacaiclub.com" class="text-grey hover:text-light transition-colors">reading@theacaiclub.com</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-charcoal shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <span class="text-grey">Mon–Fri 08:00–19:00<br/>Sat–Sun 08:00–18:00</span>
            </div>
          </div>
          <div class="mt-5">
            <a href="https://order.theacaiclub.com/RestaurantSelection/1" class="inline-flex px-6 py-2.5 bg-taupe text-white font-heading font-bold uppercase tracking-wider text-xs rounded-full hover:bg-taupe-dark transition-colors">
              Order Online
            </a>
          </div>
        </div>

        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border">
          <h3 class="font-heading font-black uppercase tracking-tight text-light text-xl mb-1">Beaconsfield</h3>
          <p class="text-grey text-sm mb-4">22 Gregories Road, HP9 1HQ</p>
          <div class="space-y-2 text-sm">
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-charcoal shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href="tel:01494370876" class="text-grey hover:text-light transition-colors">01494 370876</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-charcoal shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 4l6 6M22 4l-6 6M4 20l4-4m12 4l-4-4M12 12v8"/></svg>
              <a href="mailto:beaconsfield@theacaiclub.com" class="text-grey hover:text-light transition-colors">beaconsfield@theacaiclub.com</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-charcoal shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <span class="text-grey">Mon–Fri 08:00–19:00<br/>Sat–Sun 08:00–18:00</span>
            </div>
          </div>
          <div class="mt-5">
            <a href="https://order.theacaiclub.com/RestaurantSelection/3" class="inline-flex px-6 py-2.5 bg-taupe text-white font-heading font-bold uppercase tracking-wider text-xs rounded-full hover:bg-taupe-dark transition-colors">
              Order Online
            </a>
          </div>
        </div>

        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border">
          <h3 class="font-heading font-black uppercase tracking-tight text-light text-xl mb-1">Datchet</h3>
          <p class="text-grey text-sm mb-4">10 High Street, SL3 9EA</p>
          <div class="space-y-2 text-sm">
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-charcoal shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href="tel:01753297015" class="text-grey hover:text-light transition-colors">01753 297015</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-charcoal shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 4l6 6M22 4l-6 6M4 20l4-4m12 4l-4-4M12 12v8"/></svg>
              <a href="mailto:datchet@theacaiclub.com" class="text-grey hover:text-light transition-colors">datchet@theacaiclub.com</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-charcoal shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <span class="text-grey">Mon–Fri 08:00–19:00<br/>Sat–Sun 08:00–18:00</span>
            </div>
          </div>
          <div class="mt-5">
            <a href="https://order.theacaiclub.com/RestaurantSelection/4" class="inline-flex px-6 py-2.5 bg-taupe text-white font-heading font-bold uppercase tracking-wider text-xs rounded-full hover:bg-taupe-dark transition-colors">
              Order Online
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- General enquiries -->
  <section class="bg-dark py-20 border-t border-dark-border">
    <div class="max-w-3xl mx-auto px-8 text-center">
      <h2 class="font-heading text-2xl font-bold uppercase tracking-tight text-light mb-4">
        General Enquiries
      </h2>
      <p class="text-grey text-base leading-relaxed mb-6">
        For press, partnerships, wholesale, or anything else:
      </p>
      <a href="mailto:hello@theacaiclub.com" class="text-charcoal text-xl hover:text-light transition-colors font-heading font-semibold">
        hello@theacaiclub.com
      </a>
    </div>
  </section>

</Layout>
