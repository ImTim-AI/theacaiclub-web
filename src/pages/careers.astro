---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Careers | The Açai Club" description="Join the team. We're looking for people who love good food, good energy, & good vibes.">

  <!-- Hero -->
  <section class="relative pt-28 pb-24 bg-dark">
    <div class="max-w-[1400px] mx-auto px-8">
      <h1 class="font-heading text-5xl sm:text-6xl lg:text-8xl font-black uppercase tracking-tight text-light leading-[0.95]">
        Work<br /><span class="text-beige">with us</span>
      </h1>
      <p class="mt-8 text-grey text-lg sm:text-xl max-w-lg leading-relaxed">
        We're always looking for people who love good food, good energy, & good vibes. If that sounds like you, we'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- What we look for -->
  <section class="py-24 bg-dark-surface">
    <div class="max-w-[1400px] mx-auto px-8">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold uppercase tracking-tight text-light mb-12 text-center">
        What we look for
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border">
          <h3 class="font-heading font-normal text-light mb-3 text-lg">Energy</h3>
          <p class="text-grey text-sm leading-relaxed">You bring positive energy to every shift. You make people feel welcome the moment they walk in.</p>
        </div>
        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border">
          <h3 class="font-heading font-normal text-light mb-3 text-lg">Quality</h3>
          <p class="text-grey text-sm leading-relaxed">You care about doing things properly. Every bowl, every drink, every interaction — done right.</p>
        </div>
        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border">
          <h3 class="font-heading font-normal text-light mb-3 text-lg">Community</h3>
          <p class="text-grey text-sm leading-relaxed">You're a team player who wants to be part of something bigger. We grow together.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Perks -->
  <section class="py-24 bg-dark">
    <div class="max-w-[1400px] mx-auto px-8">
      <h2 class="font-heading text-3xl sm:text-4xl font-bold uppercase tracking-tight text-light mb-12 text-center">
        Perks
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-dark-card border border-dark-border flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-beige" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-heading font-normal text-light text-sm mb-1">Competitive Pay</h3>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-dark-card border border-dark-border flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-beige" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>
          </div>
          <h3 class="font-heading font-normal text-light text-sm mb-1">Free Bowls on Shift</h3>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-dark-card border border-dark-border flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-beige" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>
          </div>
          <h3 class="font-heading font-normal text-light text-sm mb-1">Great Team</h3>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-dark-card border border-dark-border flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-beige" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" /></svg>
          </div>
          <h3 class="font-heading font-normal text-light text-sm mb-1">Room to Grow</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- Apply CTA -->
  <section class="py-24 bg-dark-surface border-t border-dark-border">
    <div class="max-w-4xl mx-auto px-8 text-center">
      <h2 class="font-heading text-4xl sm:text-5xl font-bold uppercase tracking-tight text-light mb-6">
        Ready to<br /><span class="text-beige">join us?</span>
      </h2>
      <p class="text-grey text-lg max-w-lg mx-auto mb-10">
        Send us your CV & a few words about yourself. We'd love to hear from you.
      </p>
      <a href="mailto:careers@theacaiclub.com" class="inline-flex px-12 py-4 bg-light text-dark font-heading font-bold uppercase tracking-wider text-sm rounded-full hover:bg-light-muted transition-colors">
        Apply Now
      </a>
      <p class="text-grey text-sm mt-4">
        <a href="mailto:careers@theacaiclub.com" class="text-beige hover:text-light transition-colors">careers@theacaiclub.com</a>
      </p>
    </div>
  </section>

</Layout>
