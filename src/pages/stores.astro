---
import Layout from '../layouts/Layout.astro';

const stores = [
  {
    city: "Reading",
    slug: "reading",
    name: "The Açai Club, Reading",
    streetAddress: "85 Kings Road",
    addressLocality: "Reading",
    postalCode: "RG1 3DD",
    geo: { latitude: 51.4569, longitude: -0.9626 },
    address: "85 Kings Road, Reading RG1 3DD",
    email: "reading@theacaiclub.com",
    phone: "0118 228 8750",
    telSchema: "+441182288750",
    hours: [
      { day: "Mon–Fri", time: "08:00–19:00" },
      { day: "Sat–Sun", time: "08:00–18:00" },
    ],
    hoursSchema: [
      { dow: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: "08:00", closes: "19:00" },
      { dow: ["Saturday","Sunday"], opens: "08:00", closes: "18:00" },
    ],
    orderUrl: "https://order.theacaiclub.com/RestaurantSelection/1",
    mapsUrl: "https://www.google.com/maps/search/?api=1&query=85+Kings+Road+Reading+RG1+3DD",
    mapsEmbed: "https://maps.google.com/maps?q=85+Kings+Road+Reading+RG1+3DD&output=embed",
  },
  {
    city: "Beaconsfield",
    slug: "beaconsfield",
    name: "The Açai Club, Beaconsfield",
    streetAddress: "22 Gregories Road",
    addressLocality: "Beaconsfield",
    postalCode: "HP9 1HQ",
    geo: { latitude: 51.6101, longitude: -0.6427 },
    address: "22 Gregories Road, Beaconsfield HP9 1HQ",
    email: "beaconsfield@theacaiclub.com",
    phone: "01494 370876",
    telSchema: "+441494370876",
    hours: [
      { day: "Mon–Fri", time: "08:00–19:00" },
      { day: "Sat–Sun", time: "08:00–18:00" },
    ],
    hoursSchema: [
      { dow: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: "08:00", closes: "19:00" },
      { dow: ["Saturday","Sunday"], opens: "08:00", closes: "18:00" },
    ],
    orderUrl: "https://order.theacaiclub.com/RestaurantSelection/3",
    mapsUrl: "https://www.google.com/maps/search/?api=1&query=22+Gregories+Road+Beaconsfield+HP9+1HQ",
    mapsEmbed: "https://maps.google.com/maps?q=22+Gregories+Road+Beaconsfield+HP9+1HQ&output=embed",
  },
  {
    city: "Datchet",
    slug: "datchet",
    name: "The Açai Club, Datchet",
    streetAddress: "10 High Street",
    addressLocality: "Datchet",
    postalCode: "SL3 9EA",
    geo: { latitude: 51.4838, longitude: -0.5814 },
    address: "10 High Street, Datchet SL3 9EA",
    email: "datchet@theacaiclub.com",
    phone: "01753 297015",
    telSchema: "+441753297015",
    hours: [
      { day: "Mon–Fri", time: "08:00–19:00" },
      { day: "Sat–Sun", time: "08:00–18:00" },
    ],
    hoursSchema: [
      { dow: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: "08:00", closes: "19:00" },
      { dow: ["Saturday","Sunday"], opens: "08:00", closes: "18:00" },
    ],
    orderUrl: "https://order.theacaiclub.com/RestaurantSelection/4",
    mapsUrl: "https://www.google.com/maps/search/?api=1&query=10+High+Street+Datchet+SL3+9EA",
    mapsEmbed: "https://maps.google.com/maps?q=10+High+Street+Datchet+SL3+9EA&output=embed",
  },
];

const restaurantSchemas = stores.map((s) => ({
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  '@id': `https://theacaiclub.com/stores/#${s.slug}`,
  name: s.name,
  url: `https://theacaiclub.com/stores/`,
  image: 'https://theacaiclub.com/images/logo.jpg',
  servesCuisine: ['Açaí', 'Smoothies', 'Healthy', 'Breakfast'],
  priceRange: '££',
  telephone: s.telSchema,
  email: s.email,
  hasMenu: s.orderUrl,
  acceptsReservations: false,
  parentOrganization: { '@id': 'https://theacaiclub.com/#organization' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: s.streetAddress,
    addressLocality: s.addressLocality,
    postalCode: s.postalCode,
    addressCountry: 'GB',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: s.geo.latitude,
    longitude: s.geo.longitude,
  },
  hasMap: s.mapsUrl,
  openingHoursSpecification: s.hoursSchema.map((h) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.dow,
    opens: h.opens,
    closes: h.closes,
  })),
  potentialAction: {
    '@type': 'OrderAction',
    target: s.orderUrl,
    deliveryMethod: ['http://purl.org/goodrelations/v1#DeliveryModeOwnFleet', 'http://purl.org/goodrelations/v1#DeliveryModePickUp'],
  },
}));
---

<Layout title="Stores | The Açai Club" description="Find your nearest The Açai Club. Three UK stores in Reading, Beaconsfield, and Datchet. Addresses, opening hours, phone numbers, and online ordering." schemaJsonLd={restaurantSchemas}>

  <!-- Hero -->
  <section class="pt-28 pb-16 bg-dark">
    <div class="max-w-[1400px] mx-auto px-8 text-center">
      <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-black uppercase tracking-tight text-light leading-tight">
        Find The Açai Club<br /><span class="text-charcoal">nearest you</span>
      </h1>
      <p class="mt-4 text-grey text-lg">
        Pop in, grab a bowl & feel the vibes.
      </p>
    </div>
  </section>

  <!-- Store listings -->
  <section>
    {stores.map((store, idx) => (
      <div class={idx % 2 === 0 ? "bg-dark-surface py-20" : "bg-dark py-20"}>
        <div class="max-w-[1400px] mx-auto px-8">
          <div class="grid lg:grid-cols-2 gap-10 items-start">

            <!-- Map -->
            <div class="rounded-2xl overflow-hidden border border-dark-border aspect-[4/3]">
              <iframe
                src={store.mapsEmbed}
                width="100%"
                height="100%"
                style="border:0; filter: grayscale(20%);"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title={`Map for ${store.name}`}
              ></iframe>
            </div>

            <!-- Info -->
            <div class="flex flex-col justify-center">
              <h2 class="font-heading text-3xl sm:text-4xl font-black uppercase tracking-tight text-light leading-tight">
                {store.city}
              </h2>
              <p class="mt-2 text-grey text-base">{store.address}</p>
              <p class="mt-1 text-grey text-sm">{store.phone}</p>
              <p class="mt-1">
                <a href={`mailto:${store.email}`} class="text-charcoal text-sm hover:text-light transition-colors">{store.email}</a>
              </p>

              <!-- Hours -->
              <div class="mt-6 space-y-1">
                {store.hours.map((h) => (
                  <div class="flex items-center gap-4 text-sm">
                    <span class="text-charcoal font-heading font-semibold uppercase tracking-wider w-24">{h.day}</span>
                    <span class="text-grey">{h.time}</span>
                  </div>
                ))}
              </div>

              <!-- CTAs -->
              <div class="mt-8 flex flex-wrap gap-3">
                <a
                  href={store.orderUrl}
                  class="inline-flex px-8 py-3 bg-taupe text-white font-heading font-bold uppercase tracking-wider text-sm rounded-full hover:bg-taupe-dark transition-colors"
                >
                  Order Now
                </a>
                <a
                  href={store.mapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-8 py-3 bg-transparent text-light font-heading font-bold uppercase tracking-wider text-sm rounded-full border border-dark-border hover:bg-dark-card transition-colors"
                >
                  Get Directions
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
                </a>
              </div>
            </div>

          </div>
        </div>
      </div>
    ))}
  </section>

  <!-- More locations coming -->
  <section class="py-24 bg-dark-surface border-t border-dark-border">
    <div class="max-w-4xl mx-auto px-8 text-center">
      <h2 class="font-heading text-3xl font-bold uppercase tracking-tight text-light mb-4">
        More locations <span class="text-charcoal">coming soon</span>
      </h2>
      <p class="text-grey text-lg max-w-md mx-auto mb-10">
        We're expanding across the UK & beyond. Stay tuned.
      </p>
      <p class="text-grey text-base max-w-md mx-auto">
        Questions? Reach us at <a href="mailto:hello@theacaiclub.com" class="text-charcoal hover:text-light transition-colors">hello@theacaiclub.com</a>
      </p>
    </div>
  </section>

</Layout>
